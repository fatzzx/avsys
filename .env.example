# Copie este arquivo para .env e ajuste os valores conforme necessário.
# Em produção, use secrets do Docker / variáveis de ambiente do orquestrador.

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Portas dos serviços (desenvolvimento local sem Docker)
FLIGHT_CATALOG_PORT=3001
RESERVATION_SERVICE_PORT=3002
PAYMENT_SERVICE_PORT=3003

# Paths dos bancos SQLite (desenvolvimento local)
FLIGHT_DB_PATH=./data/flights.db
RESERVATION_DB_PATH=./data/reservations.db
PAYMENT_DB_PATH=./data/payments.db
